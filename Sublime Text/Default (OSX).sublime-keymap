    { "keys": ["command+`"], "command": "toggle_terminus_panel" },

    { "keys": ["ctrl+alt+n"], "command": "run_current_file" },
    { "keys": ["ctrl+enter"], "command": "run_current_file_interactive"},

    { "keys": ["alt+shift+f"], "command": "format_with_clang_format" },
    { "keys": ["ctrl+alt+r"], "command": "rename_current_file" },
